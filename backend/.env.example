# Puerto del servidor (Railway lo setea automáticamente)
PORT=3000

# Autenticación
JWT_SECRET=cambia-esto-por-algo-seguro
ADMIN_PASSWORD=admin

# Ruta del archivo SQLite
# En Railway: montar un Volume y usar /data/db.sqlite
DB_PATH=./data/db.sqlite

# Cloudinary (https://cloudinary.com/console)
CLOUDINARY_CLOUD_NAME=tu-cloud-name
CLOUDINARY_API_KEY=tu-api-key
CLOUDINARY_API_SECRET=tu-api-secret
# IMPORTANTE: NO uses palabras como "publicidad", "ads", "banner" en el nombre
# de la carpeta — los ad blockers las bloquean (ERR_BLOCKED_BY_CLIENT).
CLOUDINARY_FOLDER=ft-media
